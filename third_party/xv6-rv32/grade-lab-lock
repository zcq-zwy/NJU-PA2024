#!/usr/bin/env python3

import os
import sys
from gradelib import *


def pick_year():
    if len(sys.argv) > 1 and sys.argv[1] in ("2024", "2025"):
        year = sys.argv[1]
        sys.argv = [sys.argv[0]] + sys.argv[2:]
    else:
        year = os.environ.get("LOCKLAB_YEAR", "2025")
    if year not in ("2024", "2025"):
        raise SystemExit("usage: grade-lab-lock [2024|2025]")
    os.environ["LOCKLAB_YEAR"] = year
    return year


YEAR = pick_year()
r = Runner(save(f"xv6-lock-{YEAR}.out"))


if YEAR == "2024":
    @test(0, "running kalloctest")
    def test_kalloctest():
        r.run_qemu(shell_script([
            "kalloctest"
        ]), timeout=300)

    @test(10, "kalloctest: test1", parent=test_kalloctest)
    def test_kalloctest_test1():
        r.match("^test1 OK$")

